---
import Layout from "../../layouts/Layout.astro";
import DesktopGate from "../../components/DesktopGate.jsx";
import OrderValidator from "../../components/OrderValidator.jsx";
import TopNav from "../../components/TopNav.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { supabase } from "../../lib/supabase";

const title = "Validación de Pedido - Queselló!";

// Por defecto para el validador usamos la Central
const { data: franchise } = await supabase
	.from("franquicias")
	.select("*")
	.eq("id", 1)
	.single();
---

<Layout title={title}>
	<DesktopGate client:load>
		<main
			class="container"
			style="flex: 1; display: flex; flex-direction: column;"
		>
			<section
				style="flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20px 0 60px 0;"
			>
				<OrderValidator client:load />
			</section>

			<Footer />
		</main>
	</DesktopGate>
</Layout>
