---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/HeaderPost.astro";
import Footer from "../../components/Footer.astro";
import { supabase } from "../../lib/supabase";
import { marked } from "marked";

export async function getStaticPaths() {
  const { data: posts } = await supabase
    .from("posts")
    .select("slug")
    .eq("publicado", true);

  return (posts || []).map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const { data: post } = await supabase
  .from("posts")
  .select("*")
  .eq("slug", slug)
  .eq("publicado", true)
  .single();

if (!post) return Astro.redirect("/posts");

const contenidoHtml = post.contenido_md ? marked(post.contenido_md) : "";
---

<Layout
  title={`${post.titulo} | Queselló!`}
  description={post.resumen || post.subtitulo || post.titulo}
>
  <Header />
  <article
    style="max-width: 780px; margin: 0 auto; padding:40px; font-family: 'Inter', sans-serif;"
  >
    <a
      href="/posts"
      style="display: inline-flex; align-items: center; gap: 8px; color: #495D56; text-decoration: none; font-weight: 600; font-size: 14px;position:absolute;top:28px;left:30px;"
    >
      <span
        style="font-size: 12px; padding: 3px 10px; border-radius: 20px; font-weight: 500; background: rgb(209, 250, 229); color: rgb(6, 95, 70);"
      >
        « Volver</span
      >
    </a>

    {
      post.imagen_url && (
        <img
          src={post.imagen_url}
          alt={post.titulo}
          style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 24px; margin-bottom: 40px;"
        />
      )
    }

    <h1
      style="font-size: 36px; font-weight: 900; color: #1E293B; margin: 0 0 12px 0; line-height: 1.2;"
    >
      {post.titulo}
    </h1>

    {
      post.subtitulo && (
        <p style="font-size: 18px; color: #FF5E5E; font-weight: 600; margin: 0 0 20px 0;">
          {post.subtitulo}
        </p>
      )
    }

    {
      post.resumen && (
        <p style="font-size: 16px; color: #64748B; margin: 0 0 40px 0; line-height: 1.7; padding-bottom: 30px;">
          {post.resumen}
        </p>
      )
    }

    <div class="post-content" set:html={contenidoHtml} />
  </article>
  <Footer />
</Layout>

<style is:global>
  .post-content {
    font-size: 16px;
    line-height: 1.8;
    color: #334155;
    font-family: "Inter", sans-serif;
  }
  .post-content h2 {
    font-size: 26px;
    font-weight: 800;
    color: #1e293b;
    margin: 40px 0 16px;
  }
  .post-content h3 {
    font-size: 20px;
    font-weight: 700;
    color: #1e293b;
    margin: 30px 0 12px;
  }
  .post-content p {
    margin: 0 0 20px;
  }
  .post-content a {
    color: #ff5e5e;
    font-weight: 600;
  }
  .post-content ul,
  .post-content ol {
    padding-left: 24px;
    margin: 0 0 20px;
  }
  .post-content li {
    margin-bottom: 8px;
  }
  .post-content img {
    width: 100%;
    border-radius: 16px;
    margin: 24px 0;
  }
  .post-content blockquote {
    border-left: 4px solid #ff5e5e;
    padding: 12px 20px;
    background: #fff5f5;
    border-radius: 0 12px 12px 0;
    margin: 24px 0;
    color: #495d56;
    font-style: italic;
  }
  .post-content code {
    background: #f1f5f9;
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 14px;
  }
  .post-content pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 20px;
    border-radius: 16px;
    overflow-x: auto;
    margin: 24px 0;
  }
</style>
