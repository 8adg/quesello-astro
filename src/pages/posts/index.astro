---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { data: posts } = await supabase
  .from('posts')
  .select('id, slug, titulo, subtitulo, resumen, imagen_url, creado_en')
  .eq('publicado', true)
  .order('id', { ascending: false });
---

<Layout title="Blog | Queselló!" description="Artículos, novedades y consejos sobre sellos de goma y estampado artesanal.">
  <div style="max-width: 800px; margin: 0 auto; padding: 60px 20px; font-family: 'Inter', sans-serif;">
    
    <a href="/" style="display: inline-flex; align-items: center; gap: 8px; color: #495D56; text-decoration: none; font-weight: 600; font-size: 14px; margin-bottom: 40px;">
      ← Volver al inicio
    </a>

    <h1 style="font-size: 40px; font-weight: 900; color: #1E293B; margin: 0 0 8px 0;">Blog</h1>
    <p style="color: #64748B; font-size: 16px; margin: 0 0 50px 0;">Novedades, consejos y todo sobre el mundo del sello artesanal.</p>

    {posts && posts.length > 0 ? (
      <div style="display: flex; flex-direction: column; gap: 24px;">
        {posts.map(p => (
          <a href={`/posts/${p.slug}`} style="text-decoration: none; display: block; background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.06); border: 1px solid #F1F5F9; transition: transform 0.2s;">
            {p.imagen_url && (
              <img src={p.imagen_url} alt={p.titulo} style="width: 100%; height: 220px; object-fit: cover;" />
            )}
            <div style="padding: 28px;">
              <h2 style="font-size: 22px; font-weight: 800; color: #1E293B; margin: 0 0 8px 0;">{p.titulo}</h2>
              {p.subtitulo && <p style="font-size: 15px; color: #FF5E5E; font-weight: 600; margin: 0 0 12px 0;">{p.subtitulo}</p>}
              {p.resumen && <p style="font-size: 14px; color: #64748B; margin: 0 0 16px 0; line-height: 1.6;">{p.resumen}</p>}
              <span style="font-size: 13px; color: #FF5E5E; font-weight: 700;">Leer más →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="color: #94A3B8; text-align: center; padding: 60px 0;">Próximamente...</p>
    )}
  </div>
</Layout>
