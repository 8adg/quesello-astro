---
---
<section class="section" style="width: 100%; overflow: hidden;">
  <div
    id="order-card-container"
    data-aos="fade-left"
    style="width: 95vw; maxWidth: 460px; display: flex; min-height: 224px; flex-direction: column; align-items: flex-end; justify-content: center; padding: 24px 24px; border-radius: 24px; background-image: url('/pedido.png'); background-size: cover; background-position: center; color: white; text-align: right;"
  >
    <h3 style="font-family: var(--font-outfit), sans-serif; font-size: 28px; font-weight: 500; margin: 0 0 16px 0; color: white; text-transform: lowercase;">
      estado de mi pedido
    </h3>
    <p style="font-size: 16px; line-height: 22px; margin: 0 0 24px 0; color: rgba(255,255,255,0.85); text-align: right;">
      Consultá el estado de tu pedido<br />ingresando el código.
    </p>
    <button
      class="btn"
      style="margin: 0; height: 48px; padding: 0 32px; font-size: 14px; background-color: white; color: var(--primary);"
      onclick="window.location.href = '/pedidos'"
    >
      Consultar
    </button>
  </div>
</section>

<script>
  // AOS necesita un pequeño empujón si los elementos aparecen después de que se cargue la página
  // (por ejemplo, después de la hidratación de React)
  function refreshAOS() {
    if (typeof AOS !== 'undefined') {
      AOS.refresh();
    }
  }

  // Escuchamos por si React termina de hidratar
  const observer = new MutationObserver(() => {
    refreshAOS();
  });
  observer.observe(document.body, { childList: true, subtree: true });

  document.addEventListener('astro:page-load', refreshAOS);
</script>
